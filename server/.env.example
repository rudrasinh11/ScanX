# MongoDB connection string (MongoDB Atlas or local)
# Local example: mongodb://127.0.0.1:27017/scanx
# Atlas example: mongodb+srv://<user>:<password>@cluster.mongodb.net/scanx
MONGO_URI=mongodb://127.0.0.1:27017/scanx

# Port the API server listens on
PORT=5000

# URL of the deployed/running frontend, for CORS
CLIENT_URL=http://localhost:5173

# Required for the protected admin dashboard and case-study management.
# Use long, unique values in production.
ADMIN_PASSWORD=change-this-to-a-long-unique-password
ADMIN_JWT_SECRET=change-this-to-a-long-random-jwt-secret

# Required for request notifications and approval emails.
# Gmail: use smtp.gmail.com, port 465, and a Google App Password (not your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=rudrasinh3115@gmail.com
SMTP_PASS=replace-with-your-google-app-password
MAIL_FROM=rudrasinh3115@gmail.com
ADMIN_EMAIL=rudrasinh3115@gmail.com
